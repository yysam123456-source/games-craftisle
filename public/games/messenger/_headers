# Messenger 3D game — 破缓存：WASM/JS 必须可刷新
# 路径相对于本文件所在目录 (games/messenger/)

*.wasm
  Cache-Control: public, max-age=0, must-revalidate

**/*.wasm
  Cache-Control: public, max-age=0, must-revalidate

*.js
  Cache-Control: public, max-age=0, must-revalidate

**/*.js
  Cache-Control: public, max-age=0, must-revalidate

*.drc
  Cache-Control: public, max-age=0, must-revalidate

**/*.drc
  Cache-Control: public, max-age=0, must-revalidate

*.ktx2
  Cache-Control: public, max-age=0, must-revalidate

**/*.ktx2
  Cache-Control: public, max-age=0, must-revalidate
